generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum ResumeStatus {
  DRAFT
  PUBLISHED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  passwordHash  String
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  resumes       Resume[]
  aiHistory     AIHistory[]

  @@map("users")
}

model Resume {
  id            String        @id @default(cuid())
  userId        String
  title         String        @default("Untitled Resume")
  templateSlug  String        @default("modern")
  status        ResumeStatus  @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  personalInfo    PersonalInfo?
  experiences     Experience[]
  educations      Education[]
  skills          Skill[]
  projects        Project[]
  certifications  Certification[]
  languages       Language[]

  @@index([userId])
  @@map("resumes")
}

model PersonalInfo {
  id          String   @id @default(cuid())
  resumeId    String   @unique
  fullName    String
  jobTitle    String?
  email       String?
  phone       String?
  location    String?
  website     String?
  linkedin    String?
  github      String?
  portfolio   String?
  photoUrl    String?
  summary     String?  @db.Text

  resume      Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@map("personal_infos")
}

model Experience {
  id              String          @id @default(cuid())
  resumeId        String
  company         String
  position        String
  location        String?
  employmentType  EmploymentType?
  startDate       DateTime
  endDate         DateTime?
  isCurrent       Boolean         @default(false)
  description     String?         @db.Text
  sortOrder       Int             @default(0)

  resume          Resume          @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("experiences")
}

model Education {
  id           String    @id @default(cuid())
  resumeId     String
  institution  String
  degree       String
  field        String?
  location     String?
  startDate    DateTime?
  endDate      DateTime?
  grade        String?
  description  String?   @db.Text
  sortOrder    Int       @default(0)

  resume       Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("educations")
}

model Skill {
  id        String  @id @default(cuid())
  resumeId  String
  category  String
  name      String
  sortOrder Int     @default(0)

  resume    Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("skills")
}

model Project {
  id            String   @id @default(cuid())
  resumeId      String
  name          String
  description   String?  @db.Text
  techStack     String[]
  githubUrl     String?
  liveUrl       String?
  role          String?
  achievements  String?  @db.Text
  sortOrder     Int      @default(0)

  resume        Resume   @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("projects")
}

model Certification {
  id           String    @id @default(cuid())
  resumeId     String
  name         String
  issuer       String?
  issueDate    DateTime?
  credentialUrl String?
  sortOrder    Int       @default(0)

  resume       Resume    @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("certifications")
}

model Language {
  id           String  @id @default(cuid())
  resumeId     String
  name         String
  proficiency  String
  sortOrder    Int     @default(0)

  resume       Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  @@index([resumeId])
  @@map("languages")
}

model AIHistory {
  id         String   @id @default(cuid())
  userId     String
  feature    String
  inputSnapshot   String? @db.Text
  outputSnapshot  String? @db.Text
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("ai_histories")
}